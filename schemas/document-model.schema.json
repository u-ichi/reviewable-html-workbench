{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewable-html-workbench.local/schemas/document-model.schema.json",
  "title": "Reviewable HTML document model",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "title",
    "generated_at",
    "blocks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    },
    "review_settings": {
      "type": "object",
      "required": [
        "enabled",
        "mode"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "off",
            "standalone",
            "review-server"
          ]
        }
      },
      "additionalProperties": false
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "content"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "section",
              "text",
              "callout",
              "table",
              "diagram",
              "html"
            ]
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "review_required": {
            "type": "boolean"
          },
          "diagram": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "mermaid",
                  "svg",
                  "drawio",
                  "generated-image"
                ]
              },
              "source": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
