{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewable-html-workbench.local/schemas/document-model.schema.json",
  "title": "Reviewable HTML document model",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "title",
    "generated_at",
    "blocks"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    },
    "review_settings": {
      "type": "object",
      "required": [
        "enabled",
        "mode"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "off",
            "standalone",
            "review-server"
          ]
        }
      },
      "additionalProperties": false
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "heading_level",
          "content"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "section",
              "text",
              "callout",
              "table",
              "diagram",
              "image",
              "html",
              "code",
              "log"
            ]
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "review_required": {
            "type": "boolean"
          },
          "heading_level": {
            "type": "integer",
            "enum": [2, 3],
            "description": "見出しタグのレベル。2 = 章見出し (h2)、3 = 節見出し (h3)。文書タイトルが h1 を使うため、本文ブロックの見出しは h2 から始まる。"
          },
          "callout_title": {
            "type": "string"
          },
          "level": {
            "type": "string",
            "enum": ["info", "warn", "success"]
          },
          "filename": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "highlight_lines": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 }
          },
          "diagram": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "mermaid",
                  "svg",
                  "drawio",
                  "generated-image"
                ]
              },
              "source": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "diagram_kind": {
            "type": "string",
            "enum": [
              "flow",
              "state",
              "architecture",
              "matrix",
              "timeline",
              "concept"
            ]
          },
          "diagram_source": {
            "type": "string"
          },
          "image": {
            "type": "object",
            "required": [
              "prompt",
              "alt",
              "generation_status"
            ],
            "properties": {
              "prompt": {
                "type": "string",
                "minLength": 1
              },
              "alt": {
                "type": "string",
                "minLength": 1
              },
              "caption": {
                "type": "string"
              },
              "generation_status": {
                "type": "string",
                "enum": [
                  "requested",
                  "generated"
                ]
              },
              "source_path": {
                "type": "string",
                "minLength": 1
              },
              "generated_at": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
