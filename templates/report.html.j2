<!doctype html>
<html lang="{{ lang }}" data-theme="light" data-density="compact">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="assets/style.css?v={{ asset_version }}">
{{ mermaid_head }}
</head>
<body>
  <div class="app" data-document-id="{{ document_id }}">
    <header class="topbar">
      <div class="topbar-left">
        <span class="brand-mark">
          <span class="brand-glyph">RW</span>
          <span class="brand-name">Reviewable HTML Workbench</span>
        </span>
      </div>
      <div class="topbar-spacer"></div>
      <div class="toolset">
        <select class="chip-select" id="filterSelect" data-i18n="filterLabel">
          <option value="all" data-i18n="filterAll"></option>
          <option value="hide-resolved" data-i18n="filterHideResolved"></option>
          <option value="only-open" data-i18n="filterOnlyOpen"></option>
        </select>
        <button class="btn ghost" id="focusToggle" type="button" data-i18n-title="focusTitle" aria-pressed="false">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2H2v4M10 2h4v4M6 14H2v-4M10 14h4v-4"/></svg>
          <span class="ft-label" data-i18n="focusLabel"></span>
        </button>
        <button class="btn ghost" id="publishToggle" type="button" data-i18n-title="publishTitle" aria-pressed="false">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3C4.5 3 2 8 2 8s2.5 5 6 5 6-5 6-5-2.5-5-6-5Z"/><circle cx="8" cy="8" r="2"/></svg>
          <span class="pt-label" data-i18n="publishLabel"></span>
        </button>
        <button class="btn ghost" id="themeToggle" type="button" data-i18n-title="themeTitle">
          <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="3.2"/><path d="M8 1v1.6M8 13.4V15M1 8h1.6M13.4 8H15M3 3l1.1 1.1M11.9 11.9 13 13M13 3l-1.1 1.1M4.1 11.9 3 13"/></svg>
          <span class="tt-label">Dark</span>
        </button>
      </div>
    </header>
    <main class="canvas" id="canvas">
      <div class="doc-shell">
        <div class="doc-grid">
          <nav class="toc" aria-label="目次" data-i18n="tocLabel">
            <p class="toc-h" data-i18n="tocHeader"></p>
{{ toc }}
          </nav>
          <article class="doc-main">
            <div class="paper">
              <header class="doc-headrow document-header" id="document-header" data-review-block="document-header" data-block-type="header" data-review-required="false">
                <div class="doc-head-main">
                  <p class="eyebrow"><a href="https://github.com/u-ichi/reviewable-html-workbench" target="_blank" rel="noopener">{{ eyebrow }}</a></p>
                  <h1 class="doc-title">{{ title }}</h1>
                  {{ doc_status }}
                </div>
              </header>
              {{ deck }}
              {{ byline }}
              {{ meta_grid }}
              {{ summary }}
              <div class="prose autonum document-content" id="content">
{{ body }}
              </div>
            </div>
          </article>
          <aside class="cmt-rail" data-i18n="railLabel">
            <div class="cmt-rail-h">
              <span data-i18n="railHeader"></span>
              <span class="cmt-rail-count" id="cmtCount">—</span>
            </div>
            <div class="cmt-layer" id="cmtLayer"></div>
          </aside>
        </div>
      </div>
    </main>
    <div class="pub-exit" id="pubExit" role="status">
      <span class="pe-label"><b data-i18n="publishExitLabel"></b></span>
      <div class="pe-seg" role="group">
        <button class="pe-w on" data-pw="standard" data-i18n="publishStandard"></button>
        <button class="pe-w" data-pw="max" data-i18n="publishMax"></button>
      </div>
      <button class="pe-btn primary" id="pubDownloadBtn">
        <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v8m0 0 3-3M8 10 5 7M2.5 11v1.5A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V11"/></svg>
        <span data-i18n="publishDownload"></span>
      </button>
      <button class="pe-btn" id="pubExitBtn">
        <svg class="icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l8 8M12 4l-8 8"/></svg>
        <span data-i18n="publishExit"></span>
      </button>
    </div>
  </div>
  <script src="assets/review-comments.js?v={{ asset_version }}"></script>
</body>
</html>
